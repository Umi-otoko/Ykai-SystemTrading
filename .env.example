# Copia este archivo a .env y completa con tus valores
# NUNCA subas el .env a GitHub

# Binance Testnet USD-M Futures
# Crea tus keys en: https://testnet.binancefuture.com
API_KEY_BINANCE=pega_tu_testnet_api_key_aqui
API_SECRET_BINANCE=pega_tu_testnet_api_secret_aqui

# Telegram (para notificaciones)
# 1. Habla con @BotFather → /newbot → copia el token
# 2. Envía un mensaje a tu bot y abre:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    El "id" dentro de "chat" es tu TELEGRAM_CHAT_ID
TELEGRAM_TOKEN=pega_tu_bot_token_aqui
TELEGRAM_CHAT_ID=pega_tu_chat_id_aqui
